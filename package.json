{
  "name": "qumran-watch",
  "private": true,
  "version": "12.0.0",
  "description": "Herramienta litúrgica profesional con calendario 364 días, sincronización GPS y alertas ICS.",
  "author": "Cristian Salinas <gedeon1972@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ public/ test/",
    "format": "prettier --write \"src/**/*.js\" \"src/**/*.css\" \"test/**/*.js\" \"public/sw.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"src/**/*.css\" \"test/**/*.js\" \"public/sw.js\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "terser": "^5.30.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "prettier": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}
